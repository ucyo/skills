# ---------------------------------------------------------------------------
# Database type — choose one: oracle | postgres | mysql | sqlite
# ---------------------------------------------------------------------------
DB_TYPE=postgres

# ---------------------------------------------------------------------------
# Connection details
# Leave DB_USER / DB_PASSWORD / DB_HOST blank for SQLite.
# ---------------------------------------------------------------------------
DB_USER=your_username
DB_PASSWORD=your_password
DB_HOST=your_host
DB_PORT=                      # optional — uses driver default if empty
DB_NAME=your_database         # for SQLite: path to the .db file, e.g. /data/app.db

# ---------------------------------------------------------------------------
# Examples per database type:
#
# PostgreSQL
#   DB_TYPE=postgres
#   DB_HOST=localhost
#   DB_PORT=5432
#   DB_NAME=mydb
#
# MySQL / MariaDB
#   DB_TYPE=mysql
#   DB_HOST=localhost
#   DB_PORT=3306
#   DB_NAME=mydb
#
# Oracle
#   DB_TYPE=oracle
#   DB_HOST=localhost
#   DB_PORT=1521
#   DB_NAME=ORCL          # service name
#
# SQLite
#   DB_TYPE=sqlite
#   DB_NAME=/data/app.db  # path inside the proxy container
#   (DB_USER / DB_PASSWORD / DB_HOST are ignored)
# ---------------------------------------------------------------------------

# Optional
MAX_ROWS=10000
PORT=8080
